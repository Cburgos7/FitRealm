## Data Models (Supabase / PostgreSQL)

```sql
-- Users (managed by Supabase Auth, extended here)
profiles (
  id uuid references auth.users primary key,
  username text unique,
  created_at timestamptz,
  units text default 'miles',  -- 'miles' | 'km'
  is_supporter boolean default false,  -- true if Supporter Pack purchased
  is_realm_pass boolean default false,  -- true if active Realm Pass subscription
  onboarding_completed boolean default false,
  avatar jsonb default '{}'::jsonb  -- composable layer IDs: {skin_tone, hair_style, hair_color, face_shape, eyes, outfit}
)

-- Villages
villages (
  id uuid primary key,
  user_id uuid references profiles,
  name text,
  origin_lat double precision,   -- freely chosen, not real GPS
  origin_lng double precision,
  food int default 80,
  medicine int default 80,
  wood int default 80,
  morale int default 80,
  stone int default 0,            -- building material, no decay, no cap
  mile_bank decimal default 0,   -- unspent miles
  created_at timestamptz,
  grace_period_ends_at timestamptz,  -- 24hrs after created_at
  last_decay_at timestamptz,
  state text default 'thriving',  -- 'thriving' | 'struggling' | 'ruined'
  last_relocated_at timestamptz,     -- tracks last move for analytics, no cooldown enforced
  total_relocations int default 0
  streak_visual_level int default 0  -- controls which streak-based visuals are shown (0=none, 1=sprouts, 2=garden, etc.)
)

-- Activity Log (outdoor GPS + treadmill)
activities (
  id uuid primary key,
  user_id uuid references profiles,
  distance_miles decimal,
  duration_seconds int,
  movement_type text,  -- 'walking' | 'running' | 'cycling' | 'hiking' | 'treadmill' | 'indoor' | 'other'
  source text,  -- 'gps' | 'manual' | 'healthkit' | 'google_health'
  multiplier decimal default 1.0,  -- mile multiplier applied based on movement type
  activity_type text default 'fitness',  -- 'fitness' | 'expedition'
  route_storage_path text,  -- GeoJSON path in Supabase Storage, null for treadmill
  started_at timestamptz,
  ended_at timestamptz,
  miles_allocated boolean default false
)

-- Expeditions (road trips / travel events)
expeditions (
  id uuid primary key,
  user_id uuid references profiles,
  name text,  -- player-named, e.g. "Trip to Chicago"
  distance_miles decimal,
  origin_lat double precision,
  origin_lng double precision,
  destination_lat double precision,
  destination_lng double precision,
  reward_type text,  -- 'fog_reveal' | 'rare_landmark' | 'outpost' | 'legendary_site'
  reward_expires_at timestamptz,  -- for temporary outposts / bonus quest windows
  created_at timestamptz
)

-- Outposts (secondary map anchors from travel)
outposts (
  id uuid primary key,
  user_id uuid references profiles,
  expedition_id uuid references expeditions,
  name text,
  lat double precision,
  lng double precision,
  is_permanent boolean default false,  -- true if upgraded to Waypoint
  expires_at timestamptz,  -- null if permanent
  created_at timestamptz
)

-- Mile Allocations
allocations (
  id uuid primary key,
  user_id uuid references profiles,
  village_id uuid references villages,
  type text,  -- 'hunt_food' | 'gather_medicine' | 'chop_wood' | 'scout' | 'move_camp' | 'explore' | 'defend' | 'faction'
  miles_spent decimal,
  created_at timestamptz
)

-- Map Tiles (fog of war)
map_tiles (
  id uuid primary key,
  user_id uuid references profiles,
  hex_q int,   -- hex grid coordinates
  hex_r int,
  explored_at timestamptz
)

-- Factions
factions (
  id uuid primary key,
  name text,
  created_by uuid references profiles,
  created_at timestamptz,
  collective_miles decimal default 0
)

-- Faction Members
faction_members (
  faction_id uuid references factions,
  user_id uuid references profiles,
  joined_at timestamptz,
  role text default 'member',  -- 'leader' | 'member'
  primary key (faction_id, user_id)
)

-- Faction Quests
faction_quests (
  id uuid primary key,
  faction_id uuid references factions,
  target_miles decimal,
  current_miles decimal default 0,
  deadline timestamptz,
  reward text,
  status text default 'active'  -- 'active' | 'completed' | 'failed'
)

-- Faction Events (Supabase Realtime feed)
faction_events (
  id uuid primary key,
  faction_id uuid references factions,
  user_id uuid references profiles,
  event_type text,  -- 'run_logged' | 'allocation_made' | 'miles_contributed' | 'quest_completed' | 'rally_received' | 'world_event'
  description text,
  created_at timestamptz
)

-- Movement Streaks
streaks (
  id uuid primary key,
  user_id uuid references profiles,
  current_streak int default 0,
  longest_streak int default 0,
  last_activity_date date,           -- last date any movement was logged
  streak_shields int default 0,      -- max 2, earned by banking 3+ mi in a day
